{
  "name": "Dracula",
  "id": "dracula",
  "default_wallpaper": "wallpapers/dracula_ai.png",
  "gtk_color_scheme": "prefer-dark",
  "fonts": {
    "family": "JetBrainsMono Nerd Font Mono",
    "family_bold": "JetBrainsMono Nerd Font Mono Bold"
  },
  "hypr": {
    "border_size": 2,
    "gaps_out": 10,
    "rounding": 10,
    "blur": {
      "enabled": true,
      "size": 5,
      "passes": 3,
      "vibrancy": 0.2
    }
  }
}
