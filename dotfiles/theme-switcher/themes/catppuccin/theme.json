{
  "name": "Catppuccin Mocha",
  "id": "catppuccin",
  "default_wallpaper": "wallpapers/arch_logo.png",
  "fonts": {
    "family": "JetBrainsMono Nerd Font Mono",
    "family_bold": "JetBrainsMono Nerd Font Mono Bold"
  },

  "hypr": {
    "border_size": 2,
    "gaps_out": 10,
    "rounding": 10,

    "blur": {
      "enabled": true,
      "size": 8,
      "passes": 2,
      "vibrancy": 0.2
    }
  }
}
