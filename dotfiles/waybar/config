{
    "layer": "top",
    "output": "DP-1",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "custom/arch",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "custom/weather",
        "clock"
    ],
    "modules-right": [
        "tray",
        "custom/updates",
        "pulseaudio",
        "network",
        "memory",
        "cpu",
        "battery",
        "custom/swaync",
        "custom/power"
    ],
    "custom/arch": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 18'>َ°£‡</span>",
        "on-click": "$HOME/.local/bin/vsfetch",
        "tooltip": false
    },
    "hyprland/workspaces": {
        "format": "{id}",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        }
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 60,
        "separate-outputs": true
    },
    "clock": {
        "format": "  {:%H:%M  |  %a %d %b}",
        "on-click": "flatpak run com.ml4w.calendar",
        "tooltip": false
    },
    "cpu": {
        "format": "َ°چ› {usage}%",
        "tooltip": true,
        "interval": 2
    },
    "memory": {
        "format": "َ°¾† {used:0.1f}G",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "interval": 5
    },
    "network": {
        "format-wifi": "َ°–© {signalStrength}%",
        "format-ethernet": "َ°ˆ€ {ipaddr}",
        "format-disconnected": "َ°–ھ Sin red",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n{essid} ({signalStrength}%)\nâ†‘ {bandwidthUpBits}  â†“ {bandwidthDownBits}",
        "on-click": "nm-connection-editor",
        "interval": 5
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں mute",
        "format-icons": {
            "default": [
                "َ°•؟",
                "َ°–€",
                "َ°•¾"
            ]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": [
            "َ°پ؛",
            "َ°پ¼",
            "َ°پ¾",
            "َ°‚€",
            "َ°‚‚",
            "َ°پ¹"
        ],
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },
    "tray": {
        "spacing": 8,
        "icon-size": 18
    },
    "custom/power": {
        "format": "âڈ»",
        "on-click": "wlogout -b 3 -c 20 -r 20 -L 400 -R 400 -T 200 -B 200 --protocol layer-shell",
        "tooltip": false
    },
    "custom/weather": {
        "format": "{}",
        "exec": "$HOME/.config/waybar/scripts/weather.py",
        "return-type": "json",
        "interval": 3600,
        "tooltip": true,
        "on-click": "flatpak run io.github.amit9838.mousam"
    },
    "custom/swaync": {
        "format": "<span font='JetBrainsMono Nerd Font Mono 16'>{icon}</span>",
        "format-icons": {
            "none": "َ°‚ڑ",
            "notification": "َ°‚œ",
            "dnd-none": "َ°‚›",
            "dnd-notification": "َ°‚›"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
        "tooltip": false
    },
    "custom/updates": {
        "exec": "count=$(checkupdates 2>/dev/null | wc -l); [ \"$count\" -gt 0 ] && echo '{\"text\":\"َ°ڑ° '\"$count\"'\",\"class\":\"pending\"}' || echo '{\"text\":\"َ°ڑ° 0\",\"class\":\"updated\"}'",
        "return-type": "json",
        "interval": 60,
        "tooltip": false,
        "on-click": "kitty --class floating-terminal -e ~/.config/hypr/scripts/install-updates.sh"
    }
}