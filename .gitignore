# Backups generados por deploy.sh
*.bak
*.bak2
*.backup
*.pre-modularization

# Archivos generados en tiempo real
dotfiles/hypr/generated-theme.conf
dotfiles/hypr/.active_bar
dotfiles/theme-switcher/current-theme.json
