# Wallpapers (binarios, no se versionan)
dotfiles/theme-switcher/themes/*/wallpapers/
dotfiles/hypr/plugins/

# Fish variables (estado local)
dotfiles/fish/fish_variables

# GTK assets generados
dotfiles/gtk-4.0/assets/
dotfiles/gtk-4.0/gtk.css
dotfiles/gtk-4.0/gtk-dark.css

# Archivos temporales / duplicados
dotfiles/fastfetch/Copia*
