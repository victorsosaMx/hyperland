dotfiles/fastfetch/config_nuevo.jsonc
dotfiles/hyprswitch/style_1.css
dotfiles/kitty/theme.conf
dotfiles/fontconfig/fonts.conf.back

# Directorios duplicados (artefactos de cp -r anidado)
dotfiles/hypr/modules/modules/
dotfiles/hypr/scripts/scripts/
dotfiles/kitty/themes/themes/
dotfiles/theme-switcher/themes/*/templates/templates/
